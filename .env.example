# Copy this file to .env and fill in real values. .env is gitignored.
# Rotating any key here: replace the value in .env and restart the dev
# server. There is no in-app rotation flow — every key is provisioned
# from the respective provider's admin console.

# ── AI / generation providers ─────────────────────────────────────────
FAL_KEY=fal_xxx                                # fal.ai — video generation
OPENAI_API_KEY=sk-proj-xxx                     # OpenAI — face-match review, agent
GEMINI_API_KEY=AIzaSy_xxx                      # Google Gemini — image generation
RAPIDAPI_KEY=xxx                               # RapidAPI — Instagram + TikTok scraping
RAPIDAPI_HOST_INSTAGRAM=instagram-looter2.p.rapidapi.com
RAPIDAPI_HOST_TIKTOK=tiktok-scraper7.p.rapidapi.com
YOUTUBE_API_KEY=AIzaSy_xxx                     # YouTube Data API — analytics

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ── Auth (NextAuth v5) ────────────────────────────────────────────────
# Generate AUTH_SECRET / NEXTAUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=                                   # 32+ bytes base64
NEXTAUTH_SECRET=                               # keep in sync with AUTH_SECRET
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
ALLOWED_EMAILS=you@example.com,teammate@example.com   # comma-separated allowlist; blank = anyone with a Google account
NEXT_PUBLIC_HARD_SYNC_EMAILS=                  # subset that always sees fresh data, no caching

# ── Storage ───────────────────────────────────────────────────────────
# Cloudflare R2 — bucket key for uploads. Service-account JSON kept as
# a single-line value (escape newlines in private_key with \n).
UPLOAD_STORAGE_BUCKET_KEY=
GCS_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── Social posting (Late) ─────────────────────────────────────────────
# Comma-separated. Each key counts as one Late account.
LATE_API_KEYS=
# Optional manual caps: index:max,index:max
# Leave blank to let the auto-learn path populate late_api_key_limits.
LATE_API_KEY_LIMITS=

# ── Cron / background ─────────────────────────────────────────────────
# Required in production. Vercel cron + the manual analytics cron both
# check it (see proxy.ts public list).
CRON_SECRET=

# ── Misc ──────────────────────────────────────────────────────────────
PORT=3000
MAX_VIDEO_SECONDS=60
DEFAULT_TIMEZONE=Asia/Kolkata
TIKTOK_ACCOUNT_ID=
